{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "entry": ["webpack.config.js", "src/index.ts", "src/**/*.test.ts"],
    "project": ["src/**/*.ts"],
    "ignoreBinaries": ["yo"],
    "ignoreDependencies": ["ts-loader"],
    "ignoreIssues": {
        "api/**": ["unlisted", "unresolved"]
    },
    "tags": ["-lintignore"],
    "webpack": false
}
